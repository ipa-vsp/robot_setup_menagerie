<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name="techtory_franka_ros2_control" params="name prefix robot_type sim_type:='real'">

        <ros2_control name="${name}" type="system">
            <hardware>
                <xacro:if value="${sim_type == 'real'}">
                    <plugin>mock_components/GenericSystem</plugin>
                </xacro:if>
                <xacro:if value="${sim_type == 'mujoco'}">
                    <plugin>mujoco_ros2_control/MujocoSystemInterface</plugin>
                </xacro:if>
                <xacro:if value="${sim_type == 'gazebo'}">
                    <plugin>gz_ros2_control/GazeboSimSystem</plugin>
                </xacro:if>
                <xacro:if value="${sim_type == 'isaac_sim'}">
                    <plugin>topic_based_ros2_control/TopicBasedSystem</plugin>
                    <param name="joint_commands_topic">/isaac_joint_command</param>
                    <param name="joint_states_topic">/isaac_joint_states</param>
                    <param name="sum_wrapped_joint_states">true</param>
                </xacro:if>
            </hardware>

            <joint name="${prefix}${robot_type}_joint1">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">0.0</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="${prefix}${robot_type}_joint2">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">0.0</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="${prefix}${robot_type}_joint3">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">0.0</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="${prefix}${robot_type}_joint4">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">-1.57</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="${prefix}${robot_type}_joint5">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">0.0</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="${prefix}${robot_type}_joint6">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">1.57</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="${prefix}${robot_type}_joint7">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">0.785</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            
            <!-- Hand joints -->
            <joint name="${prefix}${robot_type}_finger_joint1">
                <command_interface name="position"/>
                <state_interface name="position">
                  <param name="initial_value">0.0</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <!-- finger_joint2 mimics finger_joint1 — no command interface (enforced by ros2_control).
                 The <param name="mimic"> tells topic_based_ros2_control to compute and publish its
                 command value so Isaac Sim receives equal-length arrays for all 9 actuators. -->
            <joint name="${prefix}${robot_type}_finger_joint2">
                <param name="mimic">${prefix}${robot_type}_finger_joint1</param>
                <param name="multiplier">1</param>
                <state_interface name="position">
                  <param name="initial_value">0.0</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
        </ros2_control>

        <xacro:if value="${sim_type == 'gazebo'}">
            <gazebo>
                <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
                    <parameters>$(find techtory_franka_description)/config/ros2_controllers.yaml</parameters>
                </plugin>
            </gazebo>
        </xacro:if>

    </xacro:macro>
</robot>
